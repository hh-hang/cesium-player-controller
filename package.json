{
    "name": "cesium-player-controller",
    "version": "0.1.0",
    "description": "A player controller for CesiumJS",
    "license": "MIT",
    "author": "hh-hang",
    "type": "module",
    "keywords": [
        "cesium",
        "cesiumjs",
        "player-controller",
        "character-controller",
        "rapier",
        "physics",
        "first-person",
        "third-person",
        "3d",
        "fps"
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/hh-hang/cesium-player-controller.git"
    },
    "homepage": "https://github.com/hh-hang/cesium-player-controller#readme",
    "bugs": "https://github.com/hh-hang/cesium-player-controller/issues",
    "sideEffects": false,
    "main": "./dist/index.js",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "files": [
        "dist"
    ],
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.js"
        }
    },
    "scripts": {
        "dev": "vite",
        "build": "tsup",
        "clean": "rimraf dist",
        "build:example": "vite build",
        "prepublishOnly": "npm run build"
    },
    "peerDependencies": {
        "@dimforge/rapier3d-compat": "^0.14.0",
        "cesium": ">=1.120.0"
    },
    "devDependencies": {
        "@dimforge/rapier3d-compat": "^0.14.0",
        "@types/node": "^22.0.0",
        "cesium": "^1.142.0",
        "lil-gui": "^0.21.0",
        "rimraf": "^6.0.0",
        "tsup": "^8.0.1",
        "typescript": "^5.6.0",
        "vite": "^7.3.0"
    },
    "dependencies": {
        "@loaders.gl/core": "^4.4.3",
        "@loaders.gl/draco": "^4.4.3",
        "@loaders.gl/gltf": "^4.4.3"
    },
    "overrides": {
        "esbuild": "^0.28.1"
    }
}
